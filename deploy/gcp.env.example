# Copy to deploy/gcp.env and fill in real values. Never commit deploy/gcp.env.
# One-time bootstrap: ./scripts/gcp-bootstrap-env.sh
# Routine deploys do NOT upload this file; the VM keeps ~/da-ad-hackathon/backend/.env.

NODE_ENV=production
PORT=3001
MONGODB_URI=mongodb://mongo:27017/chat
REDIS_URL=redis://redis:6379
JWT_SECRET=replace_with_long_random_hex
JWT_REFRESH_SECRET=replace_with_another_long_random_hex
UPLOAD_DIR=/uploads
FRONTEND_URL=http://YOUR_VM_IP:3000
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT=mailto:admin@example.com
TURN_USERNAME=safegroup
TURN_PASSWORD=replace_with_turn_secret
